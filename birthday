<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Birthday Surprise</title>
<style>
body{
background:#0d0d0d;
color:white;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
height:100vh;
font-family:sans-serif;
text-align:center;
overflow:hidden;
}
#text{
font-size:22px;
width:80%;
min-height:70px;
margin-bottom:30px;
}
.cake{
font-size:90px;
cursor:pointer;
}
#celebrate{
display:none;
font-size:26px;
margin-top:20px;
}
.heart{
position:absolute;
font-size:20px;
animation:float 4s linear infinite;
}
@keyframes float{
0%{transform:translateY(0);opacity:1;}
100%{transform:translateY(-600px);opacity:0;}
}
</style>
</head>
<body>

<div id="text"></div>

<div class="cake" onclick="blow()">🎂🕯️</div>

<div id="celebrate">🎉 Happy Birthday!!! 🎆</div>

<script>
let message="Happy birthday I hope you have a best day and I hope all your birthday wishes come true";
let i=0;

function type(){
if(i<message.length){
document.getElementById("text").innerHTML+=message.charAt(i);
i++;
setTimeout(type,50);
}
}
type();

function blow(){
document.querySelector(".cake").innerHTML="🎂";
document.getElementById("celebrate").style.display="block";
fireworks();
hearts();
}

function hearts(){
setInterval(()=>{
let heart=document.createElement("div");
heart.className="heart";
heart.innerHTML="💖";
heart.style.left=Math.random()*100+"vw";
heart.style.bottom="0px";
document.body.appendChild(heart);
setTimeout(()=>heart.remove(),4000);
},300);
}

function fireworks(){
alert("🎆 Make a birthday wish! 🎂");
}
</script>

</body>
</html
